# Container-deploy env vars. Jenkins writes the real .env from credentials.
# Locally: only needed if running `docker compose up` from this folder.

SNOWFLAKE_USER=YOUR_SNOWFLAKE_USER
SNOWFLAKE_ACCOUNT=RE15009-STARBREEZE
SNOWFLAKE_WAREHOUSE=USER_QUERIES
SNOWFLAKE_DATABASE=PAYDAY3_PROD
SNOWFLAKE_ROLE=SYSADMIN
SNOWFLAKE_PRIVATE_KEY_PATH=/app/keys/snowflake_key.p8
SNOWFLAKE_KEY_DIR=./keys
